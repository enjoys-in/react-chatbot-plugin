{
  "name": "@enjoys/react-chatbot-plugin",
  "version": "1.4.0",
  "description": "A customizable, plugin-based chatbot widget for React — like tawk.to but fully programmable. JSON-driven flows, async actions, custom components, theming, file uploads, and more.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enjoys-in/react-chatbot-plugin.git"
  },
  "homepage": "https://github.com/enjoys-in/react-chatbot-plugin#readme",
  "bugs": {
    "url": "https://github.com/enjoys-in/react-chatbot-plugin/issues"
  },
  "author": "Enjoys <https://github.com/enjoys-in>",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/enjoys-in"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "license": "MIT",
  "keywords": [
    "chatbot",
    "react",
    "widget",
    "tawk",
    "chat",
    "plugin",
    "conversational-ui",
    "chat-widget",
    "react-chatbot",
    "flow-builder",
    "customer-support",
    "live-chat",
    "bot",
    "form-builder",
    "glassmorphism",
    "typescript"
  ]
}
